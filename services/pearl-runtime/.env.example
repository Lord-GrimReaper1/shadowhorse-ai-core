# Pearl runtime providers
OPENAI_API_KEY=replace-with-key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=replace-with-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
XAI_API_KEY=replace-with-key
XAI_MODEL=grok-2-latest
GOOGLE_API_KEY=replace-with-key
GEMINI_MODEL=gemini-1.5-pro

# Local service
PORT=4000
NODE_ENV=development
PEARL_SAFE_MODE=false

# Voice and speech
ELEVENLABS_API_KEY=replace-with-elevenlabs-key
ELEVENLABS_VOICE_ID_RUSSIAN_BLUE=replace-with-voice-id
PEARL_VOICE_PACKAGE=pearl-default

# Approval and memory controls
PEARL_APPROVAL_TOKEN=replace-with-a-long-random-secret
MEMORY_RETENTION_DAYS=30
PEARL_POLICY_APPROVER_A_NAME=approver_a
PEARL_POLICY_APPROVER_B_NAME=approver_b
PEARL_POLICY_APPROVER_A_TOKEN=replace-with-random-secret-a
PEARL_POLICY_APPROVER_B_TOKEN=replace-with-random-secret-b

# Repositories Pearl may inspect or modify through approved developer tools.
# Separate roots with ; on Windows and : on macOS/Linux.
# Put shadowhorse-ai-core first so Pearl's own runtime is her default repository.
PEARL_REPO_ROOTS=D:\Shadowhorse Games\shadowhorse-ai-core;D:\Shadowhorse Games\Project Crossroads\GitHub\Crossroads-Game

# Web research controls.
# Brave is the recommended first provider; Tavily is useful for richer agent-style research.
PEARL_WEB_SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=replace-with-brave-search-key
TAVILY_API_KEY=replace-with-tavily-key

# Keep disabled until you want Pearl to fetch selected public pages after search.
PEARL_WEB_FETCH_ENABLED=false
